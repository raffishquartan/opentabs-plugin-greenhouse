{
  "name": "opentabs-plugin-greenhouse",
  "description": "OpenTabs plugin - list and inspect jobs on any Greenhouse-hosted public job board",
  "version": "0.1.2",
  "type": "module",
  "main": "dist/index.js",
  "keywords": [
    "opentabs-plugin",
    "opentabs",
    "mcp",
    "modelcontextprotocol",
    "chrome-extension",
    "ai-agent",
    "browser-automation",
    "greenhouse",
    "jobs",
    "ats"
  ],
  "opentabs": {
    "displayName": "Greenhouse",
    "description": "List, filter and inspect jobs on any Greenhouse-hosted public job board (e.g. boards.greenhouse.io/<company>, job-boards.greenhouse.io/<company>, job-boards.eu.greenhouse.io/<company>)",
    "urlPatterns": [
      "*://boards.greenhouse.io/*",
      "*://job-boards.greenhouse.io/*",
      "*://job-boards.eu.greenhouse.io/*"
    ],
    "homepage": "https://www.greenhouse.io"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && opentabs-plugin build",
    "dev": "tsc --watch --preserveWatchOutput & opentabs-plugin build --watch",
    "type-check": "tsc --noEmit",
    "lint": "biome lint src/",
    "lint:fix": "biome lint --fix src/",
    "format:check": "biome format src/",
    "format": "biome format --write src/",
    "check": "npm run build && npm run type-check && npm run lint && npm run format:check",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run check && npm test && npm run build"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "peerDependencies": {
    "zod": "^4.0.0"
  },
  "dependencies": {
    "@opentabs-dev/plugin-sdk": "^0.0.106",
    "turndown": "^7.2.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@opentabs-dev/plugin-tools": "^0.0.106",
    "@types/turndown": "^5.0.5",
    "@vitest/coverage-v8": "^4.1.5",
    "jiti": "^2.6.1",
    "jsdom": "^29.0.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "zod": "^4.3.6"
  },
  "license": "MIT",
  "author": "raffishquartan",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/raffishquartan/opentabs-plugin-greenhouse.git"
  },
  "homepage": "https://github.com/raffishquartan/opentabs-plugin-greenhouse",
  "bugs": {
    "url": "https://github.com/raffishquartan/opentabs-plugin-greenhouse/issues"
  }
}
